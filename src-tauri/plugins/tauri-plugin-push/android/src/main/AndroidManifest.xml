<?xml version="1.0" encoding="UTF-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Android 13+ requires this runtime permission to DISPLAY notifications.
         Manifest-merged into the app; PushPlugin.register() requests it at
         runtime. FCM delivery itself doesn't need it (only display does). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
</manifest>

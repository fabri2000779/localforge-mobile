{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set shared by every window. Tauri 2 requires every command we expose to be allow-listed here.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "deep-link:default",
    "opener:default",
    "opener:allow-open-url",
    "iap:default",
    "push:default",
    "glasstabbar:default"
  ]
}

# Node / Vite
node_modules
dist
dist-ssr
*.local
.vite

# Rust / Cargo
target
**/*.rs.bk
Cargo.lock.bak

# Tauri native shells (generated by `tauri android init` / `tauri ios init`).
# Both are device-specific and large; we don't track them in this repo.
# The CI runners regenerate them from tauri.conf.json on demand.
src-tauri/gen/android
src-tauri/gen/apple

# Editors
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
*.swp
.DS_Store
Thumbs.db

# Signing material — never commit this stuff.
# iOS provisioning profiles + p12 certs ship through GH Actions secrets.
# Android keystore is generated once, kept off Git, base64'd into a
# secret for the release workflow.
*.p12
*.mobileprovision
*.cer
*.keystore
*.jks
key.properties

# Local env overrides
.env
.env.*.local

# Vendor / personal scratch
context.md
notes.local.md

# TypeScript build info
*.tsbuildinfo
